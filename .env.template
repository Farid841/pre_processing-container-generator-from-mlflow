# =============================================================================
# .env.template — Variables d'environnement du projet
# =============================================================================
#
# UTILISATION
# -----------
# 1. Copier ce fichier : cp .env.template .env
# 2. Remplir toutes les valeurs marquées REQUIRED
# 3. Ne jamais committer .env (il est dans .gitignore)
#
# Pour la CI GitHub Actions, ces mêmes variables sont configurées dans :
# Settings → Secrets and variables → Actions → New repository secret
#
# LÉGENDE
# -------
#   REQUIRED  — doit être renseigné, rien ne fonctionnera sans
#   OPTIONAL  — valeur par défaut utilisée si absent
#   AUTO      — généré automatiquement, ne pas modifier
# =============================================================================


# =============================================================================
# MLFLOW — Serveur de tracking
# =============================================================================

# [REQUIRED] URL du serveur MLflow
# Exemple local :      http://localhost:5000
# Exemple production : http://mlflow.ton-serveur.fr:5000
MLFLOW_TRACKING_URI=

# [REQUIRED] Credentials d'authentification MLflow (HTTP Basic Auth)
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=


# =============================================================================
# S3 / MINIO — Stockage des artefacts MLflow
# =============================================================================
# MLflow utilise S3 ou MinIO pour stocker preprocessing.py, requirements.txt,
# les modèles, etc. Ces variables sont lues par boto3 automatiquement.

# [REQUIRED] Clé d'accès S3/MinIO
AWS_ACCESS_KEY_ID=

# [REQUIRED] Clé secrète S3/MinIO
AWS_SECRET_ACCESS_KEY=

# [REQUIRED pour MinIO] URL du serveur MinIO
# Laisser vide pour utiliser AWS S3 standard
# Exemple : http://minio.ton-serveur.fr:9000
AWS_ENDPOINT_URL=

# [OPTIONAL] Région AWS (défaut : us-east-1)
# Pour MinIO, laisser us-east-1 même si le serveur n'est pas en US
AWS_DEFAULT_REGION=us-east-1


# =============================================================================
# KAFKA — Connexion au broker
# =============================================================================

# [REQUIRED si KAFKA_ENABLED=true] Adresse(s) du broker Kafka
# Depuis l'hôte :               localhost:29092
# Depuis un container Docker :  kafka:9092
KAFKA_BOOTSTRAP_SERVERS=

# [OPTIONAL] Protocole de sécurité (défaut : PLAINTEXT)
# Valeurs possibles : PLAINTEXT, SASL_PLAINTEXT, SASL_SSL, SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# [OPTIONAL] Authentification SASL
# Décommenter si KAFKA_SECURITY_PROTOCOL = SASL_PLAINTEXT ou SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# [OPTIONAL] SSL (si KAFKA_SECURITY_PROTOCOL = SSL ou SASL_SSL)
# KAFKA_SSL_CA_LOCATION=/path/to/ca-cert
# KAFKA_SSL_CERT_LOCATION=/path/to/client-cert
# KAFKA_SSL_KEY_LOCATION=/path/to/client-key


# =============================================================================
# PREPROCESSING CONTAINER — Variables du container de preprocessing
# =============================================================================

# [OPTIONAL] Activer le mode Kafka (défaut : false = API REST seulement)
KAFKA_ENABLED=false

# [OPTIONAL] Topic Kafka d'entrée (défaut : fink_alerts)
INPUT_TOPIC=fink_alerts

# [OPTIONAL] Topic Kafka de sortie (défaut : preprocessed)
OUTPUT_TOPIC=preprocessed

# [OPTIONAL] Format des messages en entrée (défaut : avro)
# Valeurs possibles : avro, json, auto
INPUT_FORMAT=avro

# [OPTIONAL] Format des messages en sortie (défaut : json)
# Valeurs possibles : json, avro
OUTPUT_FORMAT=json

# [OPTIONAL] Group ID du consumer Kafka (défaut : preprocessing-group)
CONSUMER_GROUP_ID=preprocessing-group

# [OPTIONAL] Taille des batchs Kafka (défaut : 10)
BATCH_SIZE=10

# [OPTIONAL] Timeout des batchs en ms (défaut : 1000)
BATCH_TIMEOUT_MS=1000

# [OPTIONAL] Chemin du schéma Avro (défaut : /app/schemas/ztf_alert_v3.3.avsc)
AVRO_SCHEMA_PATH=/app/schemas/ztf_alert_v3.3.avsc

# [OPTIONAL] Retirer les cutouts des alertes ZTF pour réduire la taille (défaut : true)
SKIP_CUTOUTS=true

# [OPTIONAL] Port de l'API REST du container (défaut : 8000)
API_PORT=8000


# =============================================================================
# MODEL CONTAINER — Variables du container de modèle (avec bridge intégré)
# =============================================================================

# [OPTIONAL] Port du serveur MLflow dans le container modèle (défaut : 8080)
MODEL_PORT=8080

# [OPTIONAL] Chemin du modèle dans le container (défaut : /opt/ml/model)
MODEL_PATH=/opt/ml/model

# [OPTIONAL] Topic Kafka d'entrée pour le modèle (défaut : preprocessed)
# INPUT_TOPIC=preprocessed

# [OPTIONAL] Topic Kafka de sortie du modèle (défaut : predictions)
# OUTPUT_TOPIC=predictions


# =============================================================================
# DOCKER REGISTRY — Pour le push des images buildées
# =============================================================================

# [OPTIONAL] Registry Docker cible pour le push en dehors de la CI
# En CI GitHub Actions, ghcr.io est utilisé automatiquement via GITHUB_TOKEN
# Exemple : registry.ton-serveur.fr:5000
DOCKER_REGISTRY=


# =============================================================================
# INFORMATIONS MODÈLE — Renseignées automatiquement par le build
# =============================================================================
# Ces variables sont injectées dans l'image Docker par build_image.py
# à partir des tags du run MLflow.
# Tu peux les surcharger ici pour des tests locaux.

# [AUTO] Nom du modèle (lu depuis les tags MLflow : model_name)
# MODEL_NAME=

# [AUTO] Version du modèle (lu depuis les tags MLflow : version)
# MODEL_VERSION=

# [AUTO] Type de composant : preprocessing ou model
# COMPONENT_TYPE=preprocessing
